[Desktop Entry]
Version=1.0
Type=Application
Name=Reel
GenericName=Disc Ripper
Comment=Rip and backup Blu-ray and DVD discs using MakeMKV
Icon=reel
Exec=/usr/bin/reel
Terminal=false
StartupNotify=true
Categories=AudioVideo;Video;GTK;
Keywords=makemkv;blu-ray;bluray;dvd;rip;backup;mkv;disc;
MimeType=x-content/video-bluray;x-content/video-dvd;
